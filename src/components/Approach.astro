---
import { approachPoints } from '../data/site';
---

<section id="approach" class="py-24 bg-brand-muted px-6">
	<div class="max-w-7xl mx-auto">
		<div class="text-center mb-16 max-w-3xl mx-auto">
			<h2 class="text-4xl font-bold text-brand-dark mb-4 font-serif">
				Premium design, grounded in reality
			</h2>
			<p class="text-gray-600 leading-relaxed">
				Too many garden designs look stunning in a presentation — then prove expensive to build,
				difficult to maintain, or out of step with the site itself. Gardenwell takes a different
				path: refined design that respects how gardens actually live in Ireland.
			</p>
		</div>

		<div class="grid md:grid-cols-3 gap-10">
			{
				approachPoints.map((point) => (
					<div class="bg-white p-8 border border-brand-border shadow-sm">
						<h3 class="text-xl font-bold text-brand-dark mb-3 font-serif">{point.title}</h3>
						<p class="text-gray-600 leading-relaxed">{point.description}</p>
					</div>
				))
			}
		</div>
	</div>
</section>

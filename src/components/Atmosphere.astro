<div class="atmosphere" data-mode="sunshine" aria-hidden="true">
	<div class="atmosphere-tint"></div>
	<div class="sun-rays">
		<div class="sun-glow"></div>
		<div class="sun-ray sun-ray-1"></div>
		<div class="sun-ray sun-ray-2"></div>
		<div class="sun-ray sun-ray-3"></div>
		<div class="sun-ray sun-ray-4"></div>
		<div class="sun-ray sun-ray-5"></div>
	</div>
	<div class="cloud-layer">
		<div class="cloud cloud-a"></div>
		<div class="cloud cloud-b"></div>
		<div class="cloud cloud-c"></div>
		<div class="cloud cloud-d"></div>
	</div>
	<canvas class="rain-canvas"></canvas>
	<div class="night-veil"></div>
</div>

<style>
	.atmosphere {
		position: fixed;
		inset: 0;
		pointer-events: none;
		z-index: 40;
		overflow: hidden;
	}

	.atmosphere-tint {
		position: absolute;
		inset: 0;
		transition: background 1.4s ease;
		background: transparent;
	}

	/* —— Sunshine (domyślny, najczęstszy) —— */
	.atmosphere[data-mode='sunshine'] .atmosphere-tint {
		background: linear-gradient(
			155deg,
			rgba(255, 228, 160, 0.12) 0%,
			rgba(255, 248, 220, 0.05) 40%,
			rgba(180, 210, 160, 0.03) 100%
		);
	}

	/* —— Delikatny deszcz —— */
	.atmosphere[data-mode='rain'] .atmosphere-tint {
		background: linear-gradient(
			180deg,
			rgba(90, 115, 140, 0.06) 0%,
			rgba(110, 130, 155, 0.04) 50%,
			rgba(90, 115, 140, 0.05) 100%
		);
	}

	/* —— Zachmurzenie —— */
	.atmosphere[data-mode='cloud'] .atmosphere-tint {
		background: linear-gradient(
			180deg,
			rgba(140, 155, 170, 0.1) 0%,
			rgba(160, 170, 180, 0.07) 45%,
			rgba(130, 145, 160, 0.08) 100%
		);
	}

	/* —— Noc: przygaszona, ale widoczna —— */
	.atmosphere[data-mode='night'] .atmosphere-tint {
		background: linear-gradient(
			180deg,
			rgba(20, 35, 50, 0.18) 0%,
			rgba(25, 40, 55, 0.12) 50%,
			rgba(18, 32, 48, 0.16) 100%
		);
	}

	/* —— Promienie słońca —— */
	.sun-rays {
		position: absolute;
		inset: -30%;
		opacity: 0;
		transition: opacity 1.4s ease;
		pointer-events: none;
	}

	.atmosphere[data-mode='sunshine'] .sun-rays {
		opacity: 1;
	}

	.atmosphere[data-mode='cloud'] .sun-rays {
		opacity: 0.35;
	}

	.sun-glow {
		position: absolute;
		top: -5%;
		right: 8%;
		width: 45vmin;
		height: 45vmin;
		border-radius: 50%;
		background: radial-gradient(
			circle,
			rgba(255, 240, 190, 0.35) 0%,
			rgba(255, 220, 140, 0.12) 35%,
			transparent 70%
		);
		filter: blur(12px);
		animation: sunPulse 10s ease-in-out infinite alternate;
	}

	.sun-ray {
		position: absolute;
		top: -15%;
		width: 55%;
		height: 130%;
		transform-origin: top center;
		background: linear-gradient(
			180deg,
			rgba(255, 245, 200, 0.28) 0%,
			rgba(255, 230, 150, 0.1) 30%,
			rgba(255, 220, 130, 0.04) 55%,
			transparent 75%
		);
		filter: blur(6px);
		mix-blend-mode: soft-light;
		animation: sunRayDrift 16s ease-in-out infinite alternate;
	}

	.sun-ray-1 {
		left: 5%;
		--ray-rotate: -22deg;
		transform: rotate(-22deg);
	}

	.sun-ray-2 {
		left: 22%;
		--ray-rotate: -10deg;
		transform: rotate(-10deg);
		opacity: 0.85;
		animation-delay: -3s;
	}

	.sun-ray-3 {
		left: 38%;
		--ray-rotate: 2deg;
		transform: rotate(2deg);
		opacity: 0.9;
		animation-delay: -6s;
	}

	.sun-ray-4 {
		left: 52%;
		--ray-rotate: 14deg;
		transform: rotate(14deg);
		opacity: 0.7;
		animation-delay: -9s;
	}

	.sun-ray-5 {
		left: 68%;
		--ray-rotate: 24deg;
		transform: rotate(24deg);
		opacity: 0.55;
		animation-delay: -12s;
	}

	@keyframes sunPulse {
		from {
			opacity: 0.7;
			transform: scale(1);
		}
		to {
			opacity: 1;
			transform: scale(1.08);
		}
	}

	@keyframes sunRayDrift {
		from {
			opacity: 0.5;
			transform: rotate(var(--ray-rotate, -12deg)) translateX(-1.5%);
		}
		to {
			opacity: 0.95;
			transform: rotate(calc(var(--ray-rotate, -12deg) + 5deg)) translateX(2%);
		}
	}

	/* —— Chmury —— */
	.cloud-layer {
		position: absolute;
		inset: 0;
		opacity: 0;
		transition: opacity 1.4s ease;
		overflow: hidden;
	}

	.atmosphere[data-mode='cloud'] .cloud-layer,
	.atmosphere[data-mode='rain'] .cloud-layer {
		opacity: 1;
	}

	.atmosphere[data-mode='rain'] .cloud-layer {
		opacity: 0.55;
	}

	.cloud {
		position: absolute;
		border-radius: 50%;
		background: radial-gradient(
			ellipse at center,
			rgba(255, 255, 255, 0.55) 0%,
			rgba(220, 225, 230, 0.35) 45%,
			rgba(200, 210, 220, 0.15) 70%,
			transparent 100%
		);
		filter: blur(28px);
	}

	.cloud-a {
		top: 8%;
		left: -10%;
		width: 55%;
		height: 22%;
		animation: cloudDriftA 90s linear infinite;
	}

	.cloud-b {
		top: 18%;
		right: -15%;
		width: 50%;
		height: 20%;
		animation: cloudDriftB 110s linear infinite;
	}

	.cloud-c {
		top: 32%;
		left: 20%;
		width: 45%;
		height: 18%;
		opacity: 0.7;
		animation: cloudDriftC 130s linear infinite;
	}

	.cloud-d {
		top: 5%;
		left: 40%;
		width: 35%;
		height: 14%;
		opacity: 0.5;
		animation: cloudDriftA 100s linear infinite reverse;
	}

	@keyframes cloudDriftA {
		from {
			transform: translateX(0);
		}
		to {
			transform: translateX(12%);
		}
	}

	@keyframes cloudDriftB {
		from {
			transform: translateX(0);
		}
		to {
			transform: translateX(-10%);
		}
	}

	@keyframes cloudDriftC {
		from {
			transform: translateX(-5%);
		}
		to {
			transform: translateX(8%);
		}
	}

	/* —— Deszcz (canvas) —— */
	.rain-canvas {
		position: absolute;
		inset: 0;
		display: block;
		width: 100%;
		height: 100%;
		opacity: 0;
		transition: opacity 1.2s ease;
	}

	.atmosphere[data-mode='rain'] .rain-canvas {
		opacity: 1;
	}

	/* —— Noc —— */
	.night-veil {
		position: absolute;
		inset: 0;
		opacity: 0;
		transition: opacity 1.4s ease;
		background: radial-gradient(
			ellipse at 50% 15%,
			rgba(0, 0, 0, 0) 0%,
			rgba(10, 20, 35, 0.12) 50%,
			rgba(5, 15, 28, 0.22) 100%
		);
	}

	.atmosphere[data-mode='night'] .night-veil {
		opacity: 1;
	}

	@media (prefers-reduced-motion: reduce) {
		.sun-glow,
		.sun-ray,
		.cloud {
			animation: none;
		}

		.atmosphere-tint,
		.sun-rays,
		.cloud-layer,
		.rain-canvas,
		.night-veil {
			transition: none;
		}
	}
</style>

<script>
	const TIMEZONE = 'Europe/Dublin';

	type AtmosphereMode = 'sunshine' | 'rain' | 'cloud' | 'night';

	const PREVIEW_MODE: AtmosphereMode | null = null;

	function getDublinHour(): number {
		const parts = new Intl.DateTimeFormat('en-IE', {
			timeZone: TIMEZONE,
			hour: 'numeric',
			hour12: false,
		}).formatToParts(new Date());

		return Number(parts.find((part) => part.type === 'hour')?.value ?? 0);
	}

	/**
	 * Harmonogram (Dublin):
	 * - Noc: 19:00–06:59
	 * - Dzień: głównie słońce, z krótkimi oknami chmur i deszczu
	 */
	function getMode(hour: number): AtmosphereMode {
		if (hour >= 19 || hour < 7) return 'night';
		if (hour >= 7 && hour < 8) return 'cloud';
		if (hour >= 8 && hour < 11) return 'sunshine';
		if (hour >= 11 && hour < 12) return 'cloud';
		if (hour >= 12 && hour < 14) return 'sunshine';
		if (hour >= 14 && hour < 15) return 'rain';
		return 'sunshine';
	}

	function getPreviewMode(): AtmosphereMode | null {
		const param = new URLSearchParams(window.location.search).get('atmosphere');
		if (param === 'night' || param === 'sunshine' || param === 'rain' || param === 'cloud') {
			return param;
		}
		return null;
	}

	function resolveMode(): AtmosphereMode {
		return PREVIEW_MODE ?? getPreviewMode() ?? getMode(getDublinHour());
	}

	const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

	function initAtmosphere() {
		const root = document.querySelector<HTMLElement>('.atmosphere');
		const canvas = document.querySelector<HTMLCanvasElement>('.rain-canvas');
		if (!root || !canvas) return;

		const ctx = canvas.getContext('2d');
		if (!ctx) return;

		let width = 0;
		let height = 0;
		let drops: Drop[] = [];
		let animationId = 0;
		let modeCheckId = 0;
		let rainActive = false;

		class Drop {
			x = 0;
			y = 0;
			length = 0;
			speed = 0;
			opacity = 0;
			width = 0;
			angle = 0;

			constructor(randomY = false) {
				this.reset(randomY);
			}

			reset(randomY = false) {
				this.x = Math.random() * (width + 30) - 15;
				this.y = randomY ? Math.random() * height : Math.random() * -height * 0.2;
				this.length = Math.random() * 10 + 6;
				this.speed = Math.random() * 1.2 + 0.8;
				this.opacity = Math.random() * 0.06 + 0.04;
				this.width = Math.random() * 0.5 + 0.3;
				this.angle = Math.random() * 0.6 + 0.4;
			}

			fall() {
				this.y += this.speed;
				this.x += this.angle * 0.04;
				if (this.y - this.length > height) {
					this.reset();
				}
			}

			draw(context: CanvasRenderingContext2D) {
				const endX = this.x + this.angle * 0.5;
				const endY = this.y;

				context.save();
				const gradient = context.createLinearGradient(
					this.x,
					this.y - this.length,
					endX,
					endY,
				);

				gradient.addColorStop(0, 'rgba(140, 165, 190, 0)');
				gradient.addColorStop(0.6, `rgba(160, 185, 210, ${this.opacity * 0.6})`);
				gradient.addColorStop(1, `rgba(130, 155, 180, ${this.opacity})`);

				context.strokeStyle = gradient;
				context.lineWidth = this.width;
				context.lineCap = 'round';
				context.beginPath();
				context.moveTo(this.x, this.y - this.length);
				context.lineTo(endX, endY);
				context.stroke();
				context.restore();
			}
		}

		function resize() {
			const dpr = Math.min(window.devicePixelRatio || 1, 2);
			width = window.innerWidth;
			height = window.innerHeight;
			canvas.width = width * dpr;
			canvas.height = height * dpr;
			ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

			const count = Math.floor((width * height) / 14000);
			drops = Array.from({ length: Math.max(count, 40) }, () => new Drop(true));
		}

		function animateRain() {
			if (!rainActive) return;

			ctx.clearRect(0, 0, width, height);

			for (const drop of drops) {
				drop.fall();
				drop.draw(ctx);
			}

			animationId = requestAnimationFrame(animateRain);
		}

		function stopRain() {
			rainActive = false;
			cancelAnimationFrame(animationId);
			ctx.clearRect(0, 0, width, height);
		}

		function startRain() {
			if (prefersReducedMotion.matches || rainActive) return;
			rainActive = true;
			animateRain();
		}

		function applyMode(mode: AtmosphereMode) {
			root.dataset.mode = mode;

			if (mode === 'rain') {
				startRain();
			} else {
				stopRain();
			}
		}

		function syncMode() {
			applyMode(resolveMode());
		}

		resize();
		syncMode();
		modeCheckId = window.setInterval(syncMode, 60_000);

		window.addEventListener('resize', resize);

		document.addEventListener('astro:before-swap', () => {
			stopRain();
			clearInterval(modeCheckId);
			window.removeEventListener('resize', resize);
		});
	}

	initAtmosphere();
</script>

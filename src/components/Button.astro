---
interface Props {
	href?: string;
	type?: 'button' | 'submit';
	variant?: 'primary' | 'outline';
	class?: string;
}

const { href, type = 'button', variant = 'outline', class: className = '' } = Astro.props;

const base =
	'inline-flex items-center justify-center rounded-sm text-sm font-semibold tracking-wide uppercase transition-colors duration-200';

const variants = {
	primary:
		'bg-brand text-white px-8 py-4 font-bold tracking-widest hover:bg-brand-dark shadow-lg transition-all',
	outline:
		'border border-brand text-brand px-5 py-3 hover:bg-brand hover:text-white',
};

const classes = `${base} ${variants[variant]} ${className}`;
---

{
	href ? (
		<a href={href} class={classes}>
			<slot />
		</a>
	) : (
		<button type={type} class={classes}>
			<slot />
		</button>
	)
}

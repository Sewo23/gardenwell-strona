---
import { SITE } from '../data/site';
import Button from './Button.astro';
---

<section id="contact" class="py-24 px-6 max-w-7xl mx-auto flex flex-col md:flex-row gap-16">
	<div class="md:w-1/2">
		<h2 class="text-4xl font-bold text-brand-dark mb-6 font-serif">
			Let's design a garden you can actually live with.
		</h2>
		<p class="text-gray-600 mb-10 leading-relaxed">
			Tell us about your outdoor space, your budget, and how much maintenance feels right for you.
			We will help you plan a premium garden design that is honest, buildable, and suited to your
			home in Dublin, Kildare, or Meath.
		</p>

		<div class="space-y-6">
			<div>
				<p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Phone / WhatsApp</p>
				<a href={`tel:${SITE.phone}`} class="text-xl text-brand-dark font-serif hover:underline">
					{SITE.phoneDisplay}
				</a>
			</div>
			<div>
				<p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Email</p>
				<a href={`mailto:${SITE.email}`} class="text-lg text-brand-dark hover:underline">
					{SITE.email}
				</a>
			</div>
			<div>
				<p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Designing For</p>
				<p class="text-lg text-brand-dark">Dublin, Kildare & Meath</p>
			</div>
		</div>
	</div>

	<div class="md:w-1/2 bg-white p-8 border border-brand-border shadow-sm">
		<form
			name="contact"
			method="POST"
			data-netlify="true"
			data-netlify-honeypot="bot-field"
			netlify-honeypot="bot-field"
			action="/success/"
			class="space-y-4"
		>
			<input type="hidden" name="form-name" value="contact" />
			<p class="hidden" style="display: none;">
				<label>
					Don't fill this out if you're human: <input name="bot-field" />
				</label>
			</p>
			<div>
				<label for="contact-name" class="block text-sm font-semibold text-brand-dark mb-2">
					Name
				</label>
				<input
					type="text"
					id="contact-name"
					name="name"
					class="w-full border border-gray-300 p-3 rounded-sm focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent transition"
					required
				/>
			</div>
			<div>
				<label for="contact-email" class="block text-sm font-semibold text-brand-dark mb-2">
					Email
				</label>
				<input
					type="email"
					id="contact-email"
					name="email"
					class="w-full border border-gray-300 p-3 rounded-sm focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent transition"
					required
				/>
			</div>
			<div>
				<label for="contact-message" class="block text-sm font-semibold text-brand-dark mb-2">
					Message
				</label>
				<textarea
					id="contact-message"
					name="message"
					rows="4"
					placeholder="Tell us about your garden, budget, and how much upkeep you'd like..."
					class="w-full border border-gray-300 p-3 rounded-sm focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent transition"
					required
				></textarea>
			</div>
			<div>
				<label for="contact-gdpr-consent" class="flex items-start gap-3 text-sm text-gray-600 leading-relaxed cursor-pointer">
					<input
						type="checkbox"
						id="contact-gdpr-consent"
						name="gdpr-consent"
						value="yes"
						class="mt-1 shrink-0 rounded-sm border-gray-300 text-brand focus:ring-brand"
						required
					/>
					<span>
						I consent to having Gardenwell collect my personal details to respond to my inquiry.
						For more information, please read our{' '}
						<a href="/privacy-policy/" class="text-brand underline hover:text-brand-dark">
							Privacy Policy
						</a>.
					</span>
				</label>
			</div>
			<Button type="submit" variant="outline" class="w-full p-3 font-bold">
				Request a Design Consultation
			</Button>
		</form>
	</div>
</section>

<!-- Hidden form for Netlify build-time detection -->
<form name="contact" data-netlify="true" data-netlify-honeypot="bot-field" netlify-honeypot="bot-field" hidden>
	<input type="text" name="name" />
	<input type="email" name="email" />
	<textarea name="message"></textarea>
	<input type="checkbox" name="gdpr-consent" value="yes" />
	<input type="text" name="bot-field" />
</form>

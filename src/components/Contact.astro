---
import { SITE } from '../data/site';
import Button from './Button.astro';

const whatsappUrl = `https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(SITE.whatsappDefaultMessage)}`;
---

<section id="contact" class="scroll-reveal py-24 px-6 bg-white">
	<div class="max-w-7xl mx-auto flex flex-col md:flex-row gap-16">
	<div class="md:w-1/2">
		<h2 class="text-4xl font-bold text-brand-dark mb-6 font-serif">
			Let's design a garden you can actually live with.
		</h2>
		<p class="text-gray-600 mb-10 leading-relaxed">
			Tell us about your outdoor space, budget, and how much upkeep feels right — we will help you plan
			a garden design that is honest, buildable, and suited to your home in Dublin, Kildare, or Meath.
		</p>

		<div class="space-y-6">
			<div>
				<p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Phone</p>
				<a href={`tel:${SITE.phone}`} class="text-xl text-brand-dark font-serif hover:underline">
					{SITE.phoneDisplay}
				</a>
			</div>
			<div>
				<p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Email</p>
				<a href={`mailto:${SITE.email}`} class="text-lg text-brand-dark hover:underline">
					{SITE.email}
				</a>
			</div>
			<div>
				<p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">WhatsApp</p>
				<a
					href={whatsappUrl}
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex w-full items-center justify-center gap-2 rounded-sm bg-[#25D366] px-5 py-3.5 text-sm font-bold uppercase tracking-wide text-white shadow-sm transition-colors hover:bg-[#1da851] focus:outline-none focus:ring-2 focus:ring-[#25D366] focus:ring-offset-2"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="20"
						height="20"
						viewBox="0 0 24 24"
						fill="currentColor"
						aria-hidden="true"
					>
						<path
							d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.884 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
						></path>
					</svg>
					Message on WhatsApp
				</a>
				<p class="mt-2 text-sm text-gray-500 leading-relaxed">
					Only if you already use WhatsApp — opens your app or WhatsApp Web. No account needed on our
					site. Prefer email or a call? Use the form or Irish phone number above.
				</p>
			</div>
			<div>
				<p class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Designing For</p>
				<p class="text-lg text-brand-dark">Dublin, Kildare & Meath</p>
			</div>
		</div>
	</div>

	<div class="md:w-1/2 bg-white p-8 border border-brand-border shadow-sm">
		<form
			name="contact"
			method="POST"
			data-netlify="true"
			data-netlify-honeypot="bot-field"
			netlify-honeypot="bot-field"
			action="/success/"
			class="space-y-4"
		>
			<input type="hidden" name="form-name" value="contact" />
			<p class="hidden" style="display: none;">
				<label>
					Don't fill this out if you're human: <input name="bot-field" />
				</label>
			</p>
			<div>
				<label for="contact-name" class="block text-sm font-semibold text-brand-dark mb-2">
					Name
				</label>
				<input
					type="text"
					id="contact-name"
					name="name"
					class="w-full border border-gray-300 p-3 rounded-sm focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent transition"
					required
				/>
			</div>
			<div>
				<label for="contact-email" class="block text-sm font-semibold text-brand-dark mb-2">
					Email
				</label>
				<input
					type="email"
					id="contact-email"
					name="email"
					class="w-full border border-gray-300 p-3 rounded-sm focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent transition"
					required
				/>
			</div>
			<div>
				<label for="contact-message" class="block text-sm font-semibold text-brand-dark mb-2">
					Message
				</label>
				<textarea
					id="contact-message"
					name="message"
					rows="4"
					placeholder="Tell us about your garden, budget, and how much upkeep you'd like..."
					class="w-full border border-gray-300 p-3 rounded-sm focus:outline-none focus:ring-2 focus:ring-brand focus:border-transparent transition"
					required
				></textarea>
			</div>
			<div>
				<label for="contact-gdpr-consent" class="flex items-start gap-3 text-sm text-gray-600 leading-relaxed cursor-pointer">
					<input
						type="checkbox"
						id="contact-gdpr-consent"
						name="gdpr-consent"
						value="yes"
						class="mt-1 shrink-0 rounded-sm border-gray-300 text-brand focus:ring-brand"
						required
					/>
					<span>
						I consent to having Gardenwell collect my personal details to respond to my inquiry.
						For more information, please read our{' '}
						<a href="/privacy-policy/" class="text-brand underline hover:text-brand-dark">
							Privacy Policy
						</a>.
					</span>
				</label>
			</div>
			<Button type="submit" variant="outline" class="w-full p-3 font-bold">
				Request a Design Consultation
			</Button>
		</form>
	</div>
	</div>
</section>

<!-- Hidden form for Netlify build-time detection -->
<form name="contact" data-netlify="true" data-netlify-honeypot="bot-field" netlify-honeypot="bot-field" hidden>
	<input type="text" name="name" />
	<input type="email" name="email" />
	<textarea name="message"></textarea>
	<input type="checkbox" name="gdpr-consent" value="yes" />
	<input type="text" name="bot-field" />
</form>

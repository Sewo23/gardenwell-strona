---
import Button from './Button.astro';
---

<section class="scroll-reveal py-16 px-6 bg-brand-dark border-y-4 border-brand-accent">
	<div class="max-w-4xl mx-auto text-center">
		<p class="text-xs font-bold uppercase tracking-[0.2em] text-brand-light/80 mb-3">Start your project</p>
		<h2 class="text-3xl md:text-4xl font-bold text-white mb-4 font-serif">
			Ready to plan a garden you can actually live with?
		</h2>
		<p class="text-brand-light/90 mb-8 leading-relaxed max-w-2xl mx-auto">
			Tell us about your space in Dublin, Kildare, or Meath — we will help you shape a design that is
			beautiful, buildable, and suited to Irish conditions.
		</p>
		<Button
			href="#contact"
			class="!bg-white !text-brand-dark hover:!bg-brand-light !border-white pointer-events-auto"
		>
			Request a Consultation
		</Button>
	</div>
</section>

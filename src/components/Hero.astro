---
import { Image } from 'astro:assets';
import { images } from '../data/images';
import { SITE } from '../data/site';
import Button from './Button.astro';
---

<section class="relative min-h-screen overflow-hidden">
	<div class="absolute inset-0 z-0">
		<Image
			src={images.hero}
			alt="Garden design concept for an Irish home"
			width={1920}
			height={1080}
			widths={[640, 1024, 1536, 1920]}
			sizes="100vw"
			class="block h-full w-full object-cover"
			loading="eager"
			fetchpriority="high"
		/>
		<div class="absolute inset-0 bg-brand-dark/70" aria-hidden="true"></div>
	</div>

	<div class="relative z-10 flex min-h-screen items-center justify-center px-4 py-24 text-center">
		<div class="max-w-4xl mx-auto text-white mt-16">
			<h1 class="text-4xl md:text-6xl lg:text-7xl font-bold mb-5 leading-tight font-serif animate-fade-in-up">
				Garden Design in Ireland
			</h1>
			<p class="text-lg md:text-xl font-light max-w-2xl mx-auto text-gray-100 mb-3 animate-fade-in-up-delay-1">
				Bespoke garden design for homeowners across Dublin, Kildare & Meath.
			</p>
			<p class="text-base md:text-lg font-light max-w-lg mx-auto text-brand-light/90 mb-10 animate-fade-in-up-delay-1">
				{SITE.tagline}
			</p>
			<Button href="#services" variant="primary" class="animate-fade-in-up-delay-2">
				Our Services
			</Button>
		</div>
	</div>
</section>

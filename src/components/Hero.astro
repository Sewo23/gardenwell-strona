---
import { Image } from 'astro:assets';
import { images } from '../data/images';
import Button from './Button.astro';
import HeroEffects from './HeroEffects.astro';
---

<section class="relative min-h-screen overflow-hidden" data-hero>
	<div class="absolute inset-0 z-0">
		<Image
			src={images.hero}
			alt="Lush garden path with bellflowers and mature trees in Ireland"
			width={1920}
			height={1080}
			widths={[640, 1024, 1536, 1920]}
			sizes="100vw"
			class="block h-full w-full object-cover scale-105 motion-safe:transition-transform motion-safe:duration-[1200ms]"
			loading="eager"
			fetchpriority="high"
			id="hero-bg-image"
		/>
		<div class="absolute inset-0 bg-brand-dark/55 pointer-events-none" aria-hidden="true"></div>
	</div>

	<HeroEffects />

	<div
		class="relative z-10 flex min-h-screen items-center justify-center px-4 py-24 text-center pointer-events-none"
	>
		<div class="max-w-4xl mx-auto text-white mt-16">
			<h1
				class="text-4xl md:text-6xl lg:text-7xl font-bold mb-10 leading-tight font-serif animate-fade-in-up drop-shadow-[0_4px_24px_rgba(0,0,0,0.35)]"
			>
				Garden Design in Ireland
			</h1>
			<Button href="#services" variant="primary" class="pointer-events-auto animate-fade-in-up-delay-2">
				Our Services
			</Button>
		</div>
	</div>
</section>

<script>
	function initHeroBgParallax() {
		const hero = document.querySelector<HTMLElement>('[data-hero]');
		const bg = document.querySelector<HTMLElement>('#hero-bg-image');
		if (!hero || !bg) return;

		const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
		if (prefersReducedMotion.matches) return;

		const onMove = (event: MouseEvent) => {
			const rect = hero.getBoundingClientRect();
			const x = (event.clientX - rect.left) / rect.width - 0.5;
			const y = (event.clientY - rect.top) / rect.height - 0.5;
			bg.style.transform = `scale(1.08) translate(${x * -12}px, ${y * -8}px)`;
		};

		const onLeave = () => {
			bg.style.transform = 'scale(1.05) translate(0, 0)';
		};

		hero.addEventListener('mousemove', onMove);
		hero.addEventListener('mouseleave', onLeave);

		document.addEventListener('astro:before-swap', () => {
			hero.removeEventListener('mousemove', onMove);
			hero.removeEventListener('mouseleave', onLeave);
		});
	}

	initHeroBgParallax();
</script>

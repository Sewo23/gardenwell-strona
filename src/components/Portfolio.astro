---
import { Image } from 'astro:assets';
import { images } from '../data/images';

const projects = [
	{
		src: images.patio,
		alt: 'Structured floral landscape with sweeping lavender beds and stone borders in Ireland',
		title: 'Structured Floral Landscapes',
		caption:
			'Sweeping lavender beds, elegant stone borders, and manicured lawns designed to bring a touch of timeless elegance to your property.',
	},
	{
		src: images.garden,
		alt: 'Classic Irish cottage garden with vibrant perennial borders and stone pathway',
		title: 'Classic Irish Cottage Garden',
		caption:
			'Vibrant, densely planted borders bursting with traditional blooms, perfectly framing classic architecture and thriving in our local climate.',
	},
];
---

<section id="portfolio" class="py-24 px-6">
	<div class="max-w-7xl mx-auto">
		<div class="text-center mb-16 max-w-2xl mx-auto">
			<h2 class="text-4xl font-bold text-brand-dark mb-4 font-serif">Design Portfolio</h2>
			<p class="text-gray-600 leading-relaxed">
				Design concepts that aim for beauty you can live with — not show gardens that only work on
				paper.
			</p>
		</div>

		<div class="grid md:grid-cols-2 gap-8">
			{
				projects.map((project) => (
					<div class="group overflow-hidden rounded-sm relative shadow-sm bg-white">
						<Image
							src={project.src}
							alt={project.alt}
							widths={[400, 600, 800]}
							sizes="(max-width: 768px) 100vw, 50vw"
							class="w-full h-80 object-cover transform group-hover:scale-105 transition-transform duration-700"
							loading="lazy"
						/>
						<div class="p-5 border-t border-brand-border">
							<p class="font-bold text-brand-dark font-serif mb-2">{project.title}</p>
							<p class="text-sm text-gray-600 leading-relaxed">{project.caption}</p>
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>

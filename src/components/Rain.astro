<div class="rain-overlay" aria-hidden="true">
	<div class="rain-atmosphere"></div>
	<canvas class="rain-canvas"></canvas>
</div>

<style>
	.rain-overlay {
		position: fixed;
		inset: 0;
		pointer-events: none;
		z-index: 40;
		overflow: hidden;
	}

	.rain-atmosphere {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			180deg,
			rgba(80, 110, 140, 0.09) 0%,
			rgba(100, 130, 160, 0.06) 50%,
			rgba(80, 110, 140, 0.08) 100%
		);
	}

	.rain-canvas {
		position: relative;
		display: block;
		width: 100%;
		height: 100%;
	}
</style>

<script>
	const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

	function initRain() {
		if (prefersReducedMotion.matches) return;

		const canvas = document.querySelector<HTMLCanvasElement>('.rain-canvas');
		if (!canvas) return;

		const ctx = canvas.getContext('2d');
		if (!ctx) return;

		let width = 0;
		let height = 0;
		let drops: Drop[] = [];
		let animationId = 0;

		class Drop {
			x = 0;
			y = 0;
			length = 0;
			speed = 0;
			opacity = 0;
			width = 0;
			angle = 0;
			bright = false;

			constructor(randomY = false) {
				this.reset(randomY);
			}

			reset(randomY = false) {
				this.x = Math.random() * (width + 40) - 20;
				this.y = randomY ? Math.random() * height : Math.random() * -height * 0.3;
				this.length = Math.random() * 18 + 10;
				this.speed = Math.random() * 2.5 + 2;
				this.opacity = Math.random() * 0.18 + 0.22;
				this.width = Math.random() * 1 + 0.6;
				this.angle = Math.random() * 1 + 1;
				this.bright = Math.random() > 0.5;
			}

			fall() {
				this.y += this.speed;
				this.x += this.angle * 0.08;
				if (this.y - this.length > height) {
					this.reset();
				}
			}

			draw(context: CanvasRenderingContext2D) {
				const endX = this.x + this.angle;
				const endY = this.y;

				context.save();
				context.shadowBlur = 2;
				context.shadowColor = this.bright
					? 'rgba(255, 255, 255, 0.3)'
					: 'rgba(60, 100, 140, 0.25)';

				const gradient = context.createLinearGradient(
					this.x,
					this.y - this.length,
					endX,
					endY,
				);

				if (this.bright) {
					gradient.addColorStop(0, 'rgba(255, 255, 255, 0)');
					gradient.addColorStop(0.5, `rgba(255, 255, 255, ${this.opacity * 0.7})`);
					gradient.addColorStop(1, `rgba(230, 240, 255, ${this.opacity})`);
				} else {
					gradient.addColorStop(0, 'rgba(100, 140, 180, 0)');
					gradient.addColorStop(0.5, `rgba(80, 120, 170, ${this.opacity * 0.75})`);
					gradient.addColorStop(1, `rgba(50, 90, 140, ${this.opacity})`);
				}

				context.strokeStyle = gradient;
				context.lineWidth = this.width;
				context.lineCap = 'round';
				context.beginPath();
				context.moveTo(this.x, this.y - this.length);
				context.lineTo(endX, endY);
				context.stroke();
				context.restore();
			}
		}

		function resize() {
			const dpr = Math.min(window.devicePixelRatio || 1, 2);
			width = window.innerWidth;
			height = window.innerHeight;
			canvas.width = width * dpr;
			canvas.height = height * dpr;
			ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

			const count = Math.floor((width * height) / 3600);
			drops = Array.from({ length: count }, () => new Drop(true));
		}

		function animate() {
			ctx.clearRect(0, 0, width, height);

			for (const drop of drops) {
				drop.fall();
				drop.draw(ctx);
			}

			animationId = requestAnimationFrame(animate);
		}

		resize();
		animate();

		window.addEventListener('resize', resize);

		document.addEventListener('astro:before-swap', () => {
			cancelAnimationFrame(animationId);
			window.removeEventListener('resize', resize);
		});
	}

	initRain();
</script>

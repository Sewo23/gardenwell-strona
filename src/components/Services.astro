---
const services = [
	{
		title: 'Landscape Architecture',
		description:
			'Comprehensive garden design tailored to your lifestyle. We create sustainable, functional layouts that seamlessly blend with your property.',
	},
	{
		title: 'Hardscaping & Paving',
		description:
			'Premium stone patios, walkways, and retaining walls built with the highest quality materials for durability and timeless elegance.',
	},
	{
		title: 'Full Construction',
		description:
			'From groundworks to the final planting. We manage and execute the entire renovation process to deliver your dream outdoor space.',
	},
];
---

<section id="services" class="py-24 px-6 max-w-7xl mx-auto">
	<div class="text-center mb-16">
		<h2 class="text-4xl font-bold text-brand-dark mb-4 font-serif">Our Expertise</h2>
		<div class="w-24 h-1 bg-brand mx-auto opacity-50"></div>
	</div>

	<div class="grid md:grid-cols-3 gap-12">
		{
			services.map((service) => (
				<div class="bg-white p-8 border border-brand-border shadow-sm hover:shadow-md transition-shadow">
					<h3 class="text-xl font-bold text-brand-dark mb-3 font-serif">{service.title}</h3>
					<p class="text-gray-600 leading-relaxed">{service.description}</p>
				</div>
			))
		}
	</div>
</section>

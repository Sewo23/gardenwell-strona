---
import '../styles/global.css';
import Atmosphere from '../components/Atmosphere.astro';
import { SITE, services } from '../data/site';
import { images } from '../data/images';
import { getImage } from 'astro:assets';

interface Props {
	title?: string;
	description?: string;
	ogDescription?: string;
	canonicalPath?: string;
	preloadHero?: boolean;
	showRain?: boolean;
}

const {
	title = SITE.title,
	description = SITE.description,
	ogDescription = SITE.ogDescription,
	canonicalPath = '/',
	preloadHero = false,
	showRain = false,
} = Astro.props;

const canonical = new URL(canonicalPath, SITE.url).href;

const optimizedHero = preloadHero
	? await getImage({
			src: images.hero,
			width: 1200,
			height: 630,
			format: 'jpg',
			quality: 82,
		})
	: null;

const ogImageUrl = optimizedHero
	? new URL(optimizedHero.src, SITE.url).href
	: new URL('/favicon.png', SITE.url).href;

const areaLabels: Record<(typeof SITE.areasServed)[number], string> = {
	Dublin: 'County Dublin',
	Kildare: 'County Kildare',
	Meath: 'County Meath',
};

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'ProfessionalService',
	additionalType: 'https://schema.org/LandscapeArchitect',
	name: SITE.name,
	url: SITE.url,
	email: SITE.email,
	telephone: SITE.phoneDisplay,
	serviceType: 'Garden Design',
	description: SITE.description,
	image: ogImageUrl,
	areaServed: SITE.areasServed.map((area) => ({
		'@type': 'AdministrativeArea',
		name: areaLabels[area],
	})),
	address: {
		'@type': 'PostalAddress',
		addressCountry: 'IE',
	},
	contactPoint: {
		'@type': 'ContactPoint',
		telephone: SITE.phoneDisplay,
		email: SITE.email,
		contactType: 'customer service',
		areaServed: ['County Dublin', 'County Kildare', 'County Meath'],
		availableLanguage: ['English'],
	},
	hasOfferCatalog: {
		'@type': 'OfferCatalog',
		name: 'Garden Design Services',
		itemListElement: services.map((service, index) => ({
			'@type': 'Offer',
			position: index + 1,
			itemOffered: {
				'@type': 'Service',
				name: service.title,
				description: service.description,
				areaServed: ['County Dublin', 'County Kildare', 'County Meath'],
			},
		})),
	},
};
---

<!doctype html>
<html lang="en-IE" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="google-site-verification" content={SITE.googleVerification} />
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={ogDescription} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:locale" content="en_IE" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={ogDescription} />
		<meta name="twitter:image" content={ogImageUrl} />
		<link rel="canonical" href={canonical} />
		<title>{title}</title>
		<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
		<link rel="icon" type="image/png" sizes="48x48" href="/favicon-48.png" />
		<link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
		<link rel="icon" type="image/png" sizes="512x512" href="/favicon.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		{
			optimizedHero && (
				<link rel="preload" as="image" href={optimizedHero.src} fetchpriority="high" />
			)
		}
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
	</head>
	<body class="bg-brand-bg text-brand-text font-sans antialiased">
		<a
			href="#main-content"
			class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:rounded-sm focus:bg-white focus:px-4 focus:py-2 focus:text-brand-dark focus:shadow-md focus:outline-none focus:ring-2 focus:ring-brand"
		>
			Skip to content
		</a>
		{showRain && <Atmosphere />}
		<slot />
	</body>
</html>

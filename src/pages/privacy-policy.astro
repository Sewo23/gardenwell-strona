---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../data/site';

const title = 'Privacy Policy | Gardenwell';
const description =
	'Privacy Policy for Gardenwell — how we collect, use, and protect your personal data in accordance with GDPR and Irish data protection law.';
const lastUpdated = '12 June 2026';
---

<Layout
	title={title}
	description={description}
	ogDescription={description}
	canonicalPath="/privacy-policy/"
>
	<main id="main-content" class="min-h-screen">
		<header class="border-b border-brand-border bg-white/95 backdrop-blur-md">
			<div class="max-w-3xl mx-auto px-6 py-6">
				<a
					href="/"
					class="text-2xl font-bold text-brand-dark tracking-tight font-serif hover:text-brand transition-colors"
				>
					gardenwell
				</a>
			</div>
		</header>

		<article class="max-w-3xl mx-auto px-6 py-16 md:py-24">
			<p class="text-sm font-semibold uppercase tracking-wider text-gray-400 mb-3">
				Legal
			</p>
			<h1 class="text-4xl md:text-5xl font-bold text-brand-dark mb-4 font-serif">
				Privacy Policy
			</h1>
			<p class="text-sm text-gray-500 mb-12">Last updated: {lastUpdated}</p>

			<div class="space-y-10 text-gray-600 leading-relaxed">
				<section>
					<h2 class="text-2xl font-bold text-brand-dark mb-4 font-serif">1. Introduction</h2>
					<p>
						Gardenwell ("we", "us", or "our") respects your privacy and is committed to protecting
						your personal data. This Privacy Policy explains how we collect, use, store, and protect
						personal information when you visit <a
							href={SITE.url}
							class="text-brand underline hover:text-brand-dark">{SITE.url.replace('https://', '')}</a
						> or contact us about our garden design services.
					</p>
					<p class="mt-4">
						We process personal data in accordance with the General Data Protection Regulation (EU)
						2016/679 ("GDPR") and the Data Protection Act 2018 (Ireland).
					</p>
				</section>

				<section>
					<h2 class="text-2xl font-bold text-brand-dark mb-4 font-serif">2. Data Controller</h2>
					<p>
						The data controller responsible for your personal data is:
					</p>
					<ul class="mt-4 space-y-2 list-none pl-0">
						<li><strong class="text-brand-dark">Business name:</strong> Gardenwell</li>
						<li>
							<strong class="text-brand-dark">Website:</strong>
							<a href={SITE.url} class="text-brand underline hover:text-brand-dark">
								{SITE.url.replace('https://', '')}
							</a>
						</li>
						<li>
							<strong class="text-brand-dark">Email:</strong>
							<a
								href={`mailto:${SITE.email}`}
								class="text-brand underline hover:text-brand-dark">{SITE.email}</a
							>
						</li>
					</ul>
					<p class="mt-4">
						For any questions about this Privacy Policy or how we handle your data, please contact
						us at the email address above.
					</p>
				</section>

				<section>
					<h2 class="text-2xl font-bold text-brand-dark mb-4 font-serif">
						3. Types of Data We Collect
					</h2>
					<p>
						We may collect and process the following categories of personal data when you interact
						with our website or contact us:
					</p>
					<ul class="mt-4 list-disc pl-6 space-y-2">
						<li><strong class="text-brand-dark">Name</strong> — provided when you submit our contact form or communicate with us directly.</li>
						<li><strong class="text-brand-dark">Email address</strong> — provided when you submit our contact form or send us an email.</li>
						<li>
							<strong class="text-brand-dark">Phone number</strong> — if you call our Irish business line, share your number in a message, or contact us via WhatsApp (where your WhatsApp account is linked to a phone number).
						</li>
						<li>
							<strong class="text-brand-dark">WhatsApp profile information</strong> — such as your display name and any profile details made visible to us when you message Gardenwell through WhatsApp.
						</li>
						<li>
							<strong class="text-brand-dark">Message content</strong> — details about your garden project, location, budget, preferences, photos or files you choose to send, and any other information you voluntarily provide.
						</li>
						<li>
							<strong class="text-brand-dark">Technical data</strong> — limited information such as IP address, browser type, and device information may be processed by our website hosting provider for security and operational purposes.
						</li>
					</ul>
					<p class="mt-4">
						We do not intentionally collect special categories of personal data (such as health or
						sensitive information). Please avoid including unnecessary sensitive details in your
						messages.
					</p>
				</section>

				<section>
					<h2 class="text-2xl font-bold text-brand-dark mb-4 font-serif">
						4. How We Collect Your Data
					</h2>
					<p>We collect personal data when you:</p>
					<ul class="mt-4 list-disc pl-6 space-y-2">
						<li>Submit the contact form on our website;</li>
						<li>Email us directly at {SITE.email};</li>
						<li>Call our Irish business phone line at {SITE.phoneDisplay};</li>
						<li>Choose to message us via the optional WhatsApp link on our website; or</li>
						<li>Otherwise communicate with us about our garden design services.</li>
					</ul>
				</section>

				<section>
					<h2 class="text-2xl font-bold text-brand-dark mb-4 font-serif">
						5. WhatsApp Messaging (Optional)
					</h2>
					<p>
						Our website offers an <strong class="text-brand-dark">optional</strong> “Message on
						WhatsApp” button for visitors who already use WhatsApp. You are never required to install
						WhatsApp or use this channel — you can contact us by email, phone, or our contact form
						instead.
					</p>
					<p class="mt-4">
						If you click the WhatsApp button, you will be directed to WhatsApp (on your phone or via
						WhatsApp Web, depending on your device). Any message you send is received and handled by
						<strong class="text-brand-dark">Gardenwell</strong> for the purpose of responding to your
						garden design inquiry. We do not use WhatsApp for marketing broadcasts unless you have
						clearly agreed to receive them.
					</p>
					<p class="mt-4">
						When you use WhatsApp, your messages and related account information are also processed by
						<strong class="text-brand-dark">WhatsApp LLC / Meta Platforms</strong> as a separate
						service provider under WhatsApp’s own terms and privacy policy. We do not control how
						Meta processes data within the WhatsApp platform. For more information, see{' '}
						<a
							href="https://www.whatsapp.com/legal/privacy-policy"
							class="text-brand underline hover:text-brand-dark"
							rel="noopener noreferrer"
							target="_blank">WhatsApp’s Privacy Policy</a
						>.
					</p>
					<p class="mt-4">
						Please do not send sensitive personal information via WhatsApp unless necessary for your
						inquiry. For formal data protection requests, email us at{' '}
						<a href={`mailto:${SITE.email}`} class="text-brand underline hover:text-brand-dark">
							{SITE.email}
						</a>.
					</p>
				</section>

				<section>
					<h2 class="text-2xl font-bold text-brand-dark mb-4 font-serif">
						6. Purpose of Collection and Legal Basis
					</h2>
					<p>We use your personal data for the following purposes:</p>
					<ul class="mt-4 list-disc pl-6 space-y-2">
						<li>
							<strong class="text-brand-dark">Responding to inquiries and quote requests</strong> — to review your message, understand your project, and reply with relevant information about our garden design services.
						</li>
						<li>
							<strong class="text-brand-dark">Client communication</strong> — to follow up on your inquiry by email, phone, or WhatsApp (if you choose that channel), arrange consultations, and provide service-related correspondence where appropriate.
						</li>
						<li>
							<strong class="text-brand-dark">Website operation and security</strong> — to maintain the functionality and security of our website through our hosting providers.
						</li>
					</ul>
					<p class="mt-4">Our legal bases for processing under GDPR are:</p>
					<ul class="mt-4 list-disc pl-6 space-y-2">
						<li>
							<strong class="text-brand-dark">Consent (Article 6(1)(a))</strong> — when you tick the consent checkbox on our contact form before submitting your inquiry.
						</li>
						<li>
							<strong class="text-brand-dark">Legitimate interests (Article 6(1)(f))</strong> — to respond to direct communications (including optional WhatsApp messages you initiate) and operate our business securely, where this does not override your rights.
						</li>
						<li>
							<strong class="text-brand-dark">Pre-contractual steps (Article 6(1)(b))</strong> — where processing is necessary to respond to your request before entering into a design engagement.
						</li>
					</ul>
				</section>

				<section>
					<h2 class="text-2xl font-bold text-brand-dark mb-4 font-serif">
						7. Data Sharing and Processors
					</h2>
					<p>
						We do not sell your personal data. We may share your information only where necessary
						with trusted third-party service providers who assist us in operating our website and
						handling inquiries, including:
					</p>
					<ul class="mt-4 list-disc pl-6 space-y-2">
						<li>
							<strong class="text-brand-dark">Netlify, Inc.</strong> — our website hosting and form submission provider. Contact form data is transmitted to and stored by Netlify in accordance with their privacy and security practices.
						</li>
						<li>
							<strong class="text-brand-dark">WhatsApp LLC / Meta Platforms Ireland Limited</strong> — if you choose to message us via WhatsApp, message delivery and platform functionality are provided by WhatsApp. Meta may process data globally in accordance with its privacy policy and applicable transfer safeguards.
						</li>
					</ul>
					<p class="mt-4">
						These providers process data on our behalf as data processors and only in accordance
						with our instructions and applicable data protection law. Where data is transferred
						outside the European Economic Area (EEA), appropriate safeguards (such as Standard
						Contractual Clauses) are relied upon where required.
					</p>
				</section>

				<section>
					<h2 class="text-2xl font-bold text-brand-dark mb-4 font-serif">8. Data Retention</h2>
					<p>
						We retain personal data only for as long as necessary for the purposes for which it was
						collected, including:
					</p>
					<ul class="mt-4 list-disc pl-6 space-y-2">
						<li>
							<strong class="text-brand-dark">Contact form inquiries:</strong> up to 24 months after our last meaningful communication with you, unless a longer period is required to manage an ongoing project or legal obligation.
						</li>
						<li>
							<strong class="text-brand-dark">WhatsApp conversations:</strong> retained for up to 24 months after our last meaningful communication with you, unless a longer period is needed for an ongoing project or legal obligation. You may also delete messages on your side at any time within WhatsApp.
						</li>
						<li>
							<strong class="text-brand-dark">Client project records:</strong> retained for the duration of the engagement and for a reasonable period thereafter for business, tax, or legal purposes where applicable.
						</li>
					</ul>
					<p class="mt-4">
						When personal data is no longer required, we will securely delete or anonymise it.
					</p>
				</section>

				<section>
					<h2 class="text-2xl font-bold text-brand-dark mb-4 font-serif">9. Data Security</h2>
					<p>
						We take appropriate technical and organisational measures to protect your personal data
						against unauthorised access, alteration, disclosure, or destruction. These measures
						include secure website hosting, limited access to inquiry data, and use of reputable
						service providers.
					</p>
					<p class="mt-4">
						While we strive to protect your information, no method of transmission over the internet
						is completely secure. You provide information at your own risk, though we work to
						minimise that risk through responsible practices.
					</p>
				</section>

				<section>
					<h2 class="text-2xl font-bold text-brand-dark mb-4 font-serif">10. Cookies</h2>
					<p>
						Our website is primarily a static informational site and does not use advertising or
						analytics cookies. Essential cookies or similar technologies may be used by our hosting
						provider for security and basic site functionality. We do not use cookies for profiling
						or targeted marketing.
					</p>
				</section>

				<section>
					<h2 class="text-2xl font-bold text-brand-dark mb-4 font-serif">
						11. Your Rights Under GDPR
					</h2>
					<p>
						Under GDPR, if you are located in the European Economic Area (including Ireland), you
						have the following rights in relation to your personal data:
					</p>
					<ul class="mt-4 list-disc pl-6 space-y-2">
						<li><strong class="text-brand-dark">Right of access</strong> — to request a copy of the personal data we hold about you.</li>
						<li><strong class="text-brand-dark">Right to rectification</strong> — to request correction of inaccurate or incomplete data.</li>
						<li><strong class="text-brand-dark">Right to erasure</strong> — to request deletion of your personal data in certain circumstances.</li>
						<li><strong class="text-brand-dark">Right to restrict processing</strong> — to request that we limit how we use your data in certain situations.</li>
						<li><strong class="text-brand-dark">Right to data portability</strong> — to request your data in a structured, commonly used format where applicable.</li>
						<li><strong class="text-brand-dark">Right to object</strong> — to object to processing based on legitimate interests in certain circumstances.</li>
						<li>
							<strong class="text-brand-dark">Right to withdraw consent</strong> — where processing is based on consent, you may withdraw it at any time without affecting the lawfulness of processing before withdrawal.
						</li>
					</ul>
					<p class="mt-4">
						To exercise any of these rights, please contact us at{' '}
						<a href={`mailto:${SITE.email}`} class="text-brand underline hover:text-brand-dark">
							{SITE.email}
						</a>. We will respond within one month, as required by GDPR.
					</p>
					<p class="mt-4">
						You also have the right to lodge a complaint with the Irish Data Protection Commission
						(DPC):
					</p>
					<ul class="mt-4 list-none pl-0 space-y-1">
						<li>
							<a
								href="https://www.dataprotection.ie"
								class="text-brand underline hover:text-brand-dark"
								rel="noopener noreferrer"
								target="_blank">www.dataprotection.ie</a
							>
						</li>
					</ul>
				</section>

				<section>
					<h2 class="text-2xl font-bold text-brand-dark mb-4 font-serif">12. Children</h2>
					<p>
						Our services are intended for adults enquiring about garden design. We do not knowingly
						collect personal data from children under 16. If you believe we have collected such
						data, please contact us and we will delete it promptly.
					</p>
				</section>

				<section>
					<h2 class="text-2xl font-bold text-brand-dark mb-4 font-serif">
						13. Changes to This Policy
					</h2>
					<p>
						We may update this Privacy Policy from time to time to reflect changes in our practices
						or legal requirements. The "Last updated" date at the top of this page will indicate
						when the policy was most recently revised. We encourage you to review this page
						periodically.
					</p>
				</section>

				<section>
					<h2 class="text-2xl font-bold text-brand-dark mb-4 font-serif">14. Contact Us</h2>
					<p>
						If you have any questions about this Privacy Policy or wish to exercise your data
						protection rights, please contact:
					</p>
					<ul class="mt-4 list-none pl-0 space-y-2">
						<li><strong class="text-brand-dark">Gardenwell</strong></li>
						<li>
							Email:{' '}
							<a href={`mailto:${SITE.email}`} class="text-brand underline hover:text-brand-dark">
								{SITE.email}
							</a>
						</li>
						<li>
							Website:{' '}
							<a href={SITE.url} class="text-brand underline hover:text-brand-dark">
								{SITE.url.replace('https://', '')}
							</a>
						</li>
					</ul>
				</section>
			</div>

			<p class="mt-16 pt-8 border-t border-brand-border">
				<a href="/" class="text-brand font-semibold hover:text-brand-dark transition-colors">
					&larr; Back to homepage
				</a>
			</p>
		</article>

		<Footer />
	</main>
</Layout>

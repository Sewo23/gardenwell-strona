---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';

const title = 'Thank You | Gardenwell';
const description =
	'Thank you for contacting Gardenwell. We will review your inquiry and get back to you shortly.';
const ogDescription = description;
---

<Layout
	title={title}
	description={description}
	ogDescription={ogDescription}
	canonicalPath="/success/"
>
	<main id="main-content" class="min-h-screen flex items-center justify-center px-4">
		<div class="text-center max-w-2xl">
			<h1 class="text-5xl md:text-6xl font-bold mb-6 font-serif text-brand-dark">Thank you!</h1>
			<p class="text-2xl md:text-3xl mb-4 font-serif text-brand-dark">
				Your message has been sent.
			</p>
			<p class="text-lg text-gray-600 mb-12 leading-relaxed">
				We appreciate you reaching out. Our team will review your inquiry and get back to you
				shortly with a detailed response about your garden project.
			</p>
			<Button href="/">Back to Homepage</Button>
		</div>
	</main>
</Layout>
